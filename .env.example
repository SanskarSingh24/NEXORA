# NEXORA Platform — Environment Variable Template
# ============================================================
# Copy this file to `.env` and fill in real values before
# starting any NEXORA service.
#
#   cp .env.example .env
#
# NEVER commit the real .env file to version control.
# The .gitignore in this repository already excludes it.
# ============================================================


# ============================================================
# SECURITY — REQUIRED
# ============================================================

# HS256 signing secret for JWT access tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Minimum 32 characters. Must differ from NEXORA_REFRESH_SECRET.
NEXORA_JWT_SECRET=

# HS256 signing secret for JWT refresh tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Minimum 32 characters. Must differ from NEXORA_JWT_SECRET.
NEXORA_REFRESH_SECRET=


# ============================================================
# DATABASE — REQUIRED
# ============================================================

# PostgreSQL connection string (TimescaleDB-compatible).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
NEXORA_DB_URL=


# ============================================================
# MACHINE LEARNING — REQUIRED
# ============================================================

# Absolute or relative path to the trained XGBoost model file.
# Supported formats: .joblib, .json
NEXORA_ML_MODEL_PATH=


# ============================================================
# JWT TOKEN LIFETIMES — OPTIONAL (safe defaults shown)
# ============================================================

# Lifetime of access tokens in minutes. Range: 1–60. Default: 15.
# NEXORA_ACCESS_TOKEN_EXPIRE_MINUTES=15

# Lifetime of refresh tokens in days. Range: 1–30. Default: 7.
# NEXORA_REFRESH_TOKEN_EXPIRE_DAYS=7

# JWT signing algorithm. Supported: HS256, HS384, HS512. Default: HS256.
# NEXORA_JWT_ALGORITHM=HS256


# ============================================================
# CORS — OPTIONAL (restrictive default: localhost only)
# ============================================================

# Comma-separated list of allowed CORS origins.
# Example for production: https://dashboard.nexora.io,https://ops.nexora.io
# NEXORA_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
